{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri-v2-docs/main/src/content/docs/.vitepress/schemas/config.schema.json",
  "productName": "LiveMark",
  "version": "2.8.2",
  "identifier": "com.livemark.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "txt"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      }
    ]
  },
  "app": {
    "windows": [
      {
        "title": "LiveMark",
        "width": 900,
        "height": 700,
        "minWidth": 480,
        "minHeight": 360,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:"
    }
  }
}
